    classDef admin fill:#ef6c00,stroke:#b53d00,color:#fff
    classDef infraContainer fill:#f57c00,stroke:#bf5f00,color:#fff
    classDef dataContainer fill:#6a1b9a,stroke:#4a148c,color:#fff

    class Comerciante,Ops person
