{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "MassTransit": "Warning"
      }
    }
  },
  "ConnectionStrings": {
    "Postgres": "Host=postgres;Port=5432;Database=cashflow;Username=app_balance;Password=balance_pwd;Include Error Detail=true"
  },
  "RabbitMq": {
    "Host": "rabbitmq",
    "User": "guest",
    "Password": "guest"
  },
  "Authentication": {
    "Jwt": {
      "Issuer": "cashflow",
      "Audience": "cashflow-api",
      "SecretKey": "REPLACE_WITH_AT_LEAST_32_BYTES_HMAC_SHA256_KEY_PROD",
      "TokenExpirationMinutes": 15
    }
  },
  "RateLimiting": {
    "Balance": {
      "WindowSeconds": 1,
      "PermitLimit": 50,
      "QueueLimit": 5,
      "RetryAfterSeconds": "1"
    }
  },
  "AllowedHosts": "*"
}
