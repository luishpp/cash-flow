{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    }
  },
  "ConnectionStrings": {
    "Postgres": "Host=postgres;Port=5432;Database=cashflow;Username=app_identity;Password=identity_pwd;Include Error Detail=true"
  },
  "Authentication": {
    "Jwt": {
      "Issuer": "cashflow",
      "Audience": "cashflow-api",
      "SecretKey": "REPLACE_WITH_AT_LEAST_32_BYTES_HMAC_SHA256_KEY_PROD",
      "TokenExpirationMinutes": 15
    },
    "Lockout": {
      "MaxFailedAttempts": 5,
      "LockoutDuration": "00:15:00"
    },
    "RefreshToken": {
      "Lifetime": "7.00:00:00",
      "TokenBytes": 32
    }
  },
  "AllowedHosts": "*"
}
